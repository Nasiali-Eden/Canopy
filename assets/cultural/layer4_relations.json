  "indexes": [
    { "fields": ["from_entry_id", "status"],                   "note": "All confirmed relations from an entry — entry detail page forward links" },
    { "fields": ["to_entry_id", "status"],                     "note": "All confirmed relations pointing to an entry — entry detail page reverse links" },
    { "fields": ["from_entry_id", "relation_type", "status"],  "note": "Specific relation type filter on an entry" },
    { "fields": ["status", "from_content_type"],               "note": "Council queue — unconfirmed suggestions by content type" },
    { "fields": ["suggested_by_uid", "status"],                "note": "Community member contribution history" },
    { "fields": ["confirmed_by_uid", "confirmed_at"],          "note": "Council activity audit" }
  ]
}
