{
  "_file": "layer4_relations.json",
  "_description": "Typed links between two cultural entries. Every relation is directional but rendered bidirectionally — both linked entries display the relationship from their own perspective. AI suggests, orgs and community members propose, council confirms.",
  "_collection": "cultural_relations",

  "schema": {
    "id":                       { "type": "string",     "required": true },
    "from_entry_id":            { "type": "string",     "required": true,  "ref": "cultural_entries/{id}" },
    "to_entry_id":              { "type": "string",     "required": true,  "ref": "cultural_entries/{id}" },
    "from_content_type":        { "type": "string",     "required": true,  "note": "Denormalised — avoids a join on list queries" },
    "to_content_type":          { "type": "string",     "required": true,  "note": "Denormalised" },
    "relation_type":            { "type": "string",     "required": true,
      "enum": [
        "food_served_in_ceremony", "music_played_in_ceremony", "clothing_worn_in_ceremony",
        "craft_used_in_ceremony", "story_explains_tradition", "craft_produces_clothing",
        "craft_produces_instrument", "ingredient_used_in_food", "ingredient_used_in_medicine",
        "ingredient_used_in_craft", "music_uses_instrument", "place_site_of_ceremony",
        "language_names_tradition", "person_holds_knowledge", "craft_links_to_marketplace",
        "same_tradition_variant", "cross_community_parallel", "historical_precedes",
        "diaspora_variation", "other"
      ]
    },
    "label_forward":            { "type": "string",     "required": true,  "note": "How the relation reads from from_entry perspective. e.g. Played during" },
    "label_reverse":            { "type": "string",     "required": true,  "note": "How the relation reads from to_entry perspective. e.g. Music includes" },
    "relation_note":            { "type": "string",     "required": false, "note": "Specific explanatory note for this particular link" },
    "status":                   { "type": "string",     "required": true,  "default": "suggested_by_ai",
      "enum": ["suggested_by_ai", "suggested_by_community", "suggested_by_org", "confirmed", "rejected"]
    },
    "strength":                 { "type": "string",     "required": true,
      "enum": ["strong", "moderate", "speculative"]
    },
    "suggested_by_uid":         { "type": "string",     "required": false },
    "suggested_via_comment_id": { "type": "string",     "required": false, "ref": "cultural_comments/{id}" },
    "confirmed_by_uid":         { "type": "string",     "required": false },
    "created_at":               { "type": "timestamp",  "required": true },
    "confirmed_at":             { "type": "timestamp",  "required": false }
  },

  "relation_type_catalogue": {
    "food_served_in_ceremony":     { "forward": "Served during",           "reverse": "Includes food",             "valid_from": ["food_tradition"],     "valid_to": ["ceremony"] },
    "music_played_in_ceremony":    { "forward": "Played during",           "reverse": "Music includes",            "valid_from": ["music_tradition"],    "valid_to": ["ceremony"] },
    "clothing_worn_in_ceremony":   { "forward": "Worn during",             "reverse": "Dress includes",            "valid_from": ["clothing_tradition"], "valid_to": ["ceremony"] },
    "craft_used_in_ceremony":      { "forward": "Used in",                 "reverse": "Uses craft",                "valid_from": ["craft_technique"],    "valid_to": ["ceremony"] },
    "story_explains_tradition":    { "forward": "Origin story of",         "reverse": "Explained by story",        "valid_from": ["oral_tradition"],     "valid_to": ["ceremony","food_tradition","place_knowledge","craft_technique","clothing_tradition"] },
    "craft_produces_clothing":     { "forward": "Used to make",            "reverse": "Made using",                "valid_from": ["craft_technique"],    "valid_to": ["clothing_tradition"] },
    "craft_produces_instrument":   { "forward": "Used to make",            "reverse": "Made using",                "valid_from": ["craft_technique"],    "valid_to": ["instrument"] },
    "ingredient_used_in_food":     { "forward": "Key ingredient in",       "reverse": "Uses ingredient",           "valid_from": ["ingredient"],         "valid_to": ["food_tradition"] },
    "ingredient_used_in_medicine": { "forward": "Used in",                 "reverse": "Uses ingredient",           "valid_from": ["ingredient"],         "valid_to": ["medicine_knowledge"] },
    "ingredient_used_in_craft":    { "forward": "Material for",            "reverse": "Uses material",             "valid_from": ["ingredient"],         "valid_to": ["craft_technique"] },
    "music_uses_instrument":       { "forward": "Played on",               "reverse": "Featured in",               "valid_from": ["music_tradition"],    "valid_to": ["instrument"] },
    "place_site_of_ceremony":      { "forward": "Site of",                 "reverse": "Takes place at",            "valid_from": ["place_knowledge"],    "valid_to": ["ceremony"] },
    "language_names_tradition":    { "forward": "Names this tradition as", "reverse": "Named in language",         "valid_from": ["language_entry"],     "valid_to": ["oral_tradition","food_tradition","ceremony","craft_technique","music_tradition"] },
    "person_holds_knowledge":      { "forward": "Knowledge holder for",    "reverse": "Held by",                   "valid_from": ["person"],             "valid_to": ["oral_tradition","craft_technique","medicine_knowledge","music_tradition","language_entry"] },
    "craft_links_to_marketplace":  { "forward": "Practiced by",            "reverse": "Technique in archive",      "valid_from": ["craft_technique"],    "valid_to": ["marketplace_artisan"], "note": "Cross-layer link to Layer 2" },
    "same_tradition_variant":      { "forward": "Variant of",              "reverse": "Has variant",               "valid_from": "any",                  "valid_to": "any" },
    "cross_community_parallel":    { "forward": "Similar tradition in",    "reverse": "Similar tradition in",      "valid_from": "any",                  "valid_to": "any", "note": "AI suggests these most frequently" },
    "historical_precedes":         { "forward": "Historically precedes",   "reverse": "Follows from",              "valid_from": "any",                  "valid_to": "any" },
    "diaspora_variation":          { "forward": "Diaspora variation of",   "reverse": "In-Africa origin",          "valid_from": "any",                  "valid_to": "any" },
    "other":                       { "forward": "Related to",              "reverse": "Related to",                "valid_from": "any",                  "valid_to": "any", "note": "relation_note required when using other" }
  },

  "status_visibility_rules": {
    "suggested_by_ai":        { "visible_on_entry_page": false, "visible_in_org_connections_screen": true,  "org_actions": ["endorse","dismiss"] },
    "suggested_by_community": { "visible_on_entry_page": false, "visible_in_org_connections_screen": true,  "org_actions": ["endorse","dismiss"],   "council_actions": ["confirm","reject"] },
    "suggested_by_org":       { "visible_on_entry_page": false, "visible_in_org_connections_screen": true,  "council_actions": ["confirm","reject"] },
    "confirmed":              { "visible_on_entry_page": true,  "visible_in_org_connections_screen": true,  "council_actions": ["reverse"] },
    "rejected":               { "visible_on_entry_page": false, "visible_in_org_connections_screen": false, "note": "Kept for audit. Not shown to users." }
  },

