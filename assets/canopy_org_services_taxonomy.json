    {
      "serviceId": "svc_training_workshop",
      "label": "Training & Workshops",
      "icon": "co_present",
      "description": "Structured learning sessions on a specific skill or topic, open to community members",
      "deliveryModes": ["in_person", "online", "hybrid"],
      "suggestedFor": [
        "ot_ngo_environment", "ot_cbo_environment", "ot_recycling_org",
        "ot_vocational", "ot_digital_hub", "ot_enterprise_support",
        "ot_artisan_collective", "ot_football_club"
      ],
      "requiresBooking": true,
      "canEarnImpactPoints": true,
      "fields": {
        "sessionDurationMinutes": "number",
        "maxParticipants": "number",
        "recurrence": "enum:once|weekly|monthly|custom",
